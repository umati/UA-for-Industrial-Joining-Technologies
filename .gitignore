# =============================================================================
#  UA for Industrial Joining Technologies — root .gitignore
#  Applies to the entire monorepo.
# =============================================================================

# ---------------------------------------------------------------------------
# Python — applies to all sub-projects
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
venv/
venv_test/
.venv/
.venv-wsl/
.venv*/
ENV/
env/

# Certificates / keys
*.der
*.pem

# ---------------------------------------------------------------------------
# Node.js — applies to all sub-projects
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------------
# Logs and runtime state — applies to all sub-projects
# ---------------------------------------------------------------------------
logs/
*.log
*.log.*
.state/

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
.env
# .env.example files are committed — they are templates with no real secrets

# Local session / developer working notes — never commit
SESSION_NOTES.md

# ---------------------------------------------------------------------------
# OS artefacts
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
Temp/
OLD/

# ---------------------------------------------------------------------------
# IDEs
# ---------------------------------------------------------------------------
.vscode/
.vs/
.idea/
*.swp
*.swo
*.code-workspace

# ---------------------------------------------------------------------------
# Testing artefacts
# ---------------------------------------------------------------------------
.pytest_cache/
test-results/
playwright-report/
*.tmp
.setup_timestamp

# ---------------------------------------------------------------------------
# Coverage
# ---------------------------------------------------------------------------
.coverage
htmlcov/
coverage.xml
*.cover

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.docker-build-cache/
MockCache/

