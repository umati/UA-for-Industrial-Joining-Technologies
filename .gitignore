# =============================================================================
#  UA for Industrial Joining Technologies — root .gitignore
#  Applies to the entire monorepo.
# =============================================================================

# ---------------------------------------------------------------------------
# Python — applies to all sub-projects
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.egg-info/
[Dd][Ii][Ss][Tt]/
[Bb][Uu][Ii][Ll][Dd]/
.eggs/
*.egg

# Ruff (Python linter) cache
.ruff_cache/

# Mypy (Python type checker) cache
.mypy_cache/

# Virtual environments — canonical names: .venv (runtime) and .venv_test (tests).
# Docker runtime uses /opt/ijt_venv inside the container.
# Legacy aliases (.venv_wsl, venv, venv_test, etc.) are kept here as a safety
# net for developer machines mid-transition.
.venv*/
venv/
venv_test/
ENV/
env/

# Certificates / keys
*.der
*.pem

# ---------------------------------------------------------------------------
# Node.js — applies to all sub-projects
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------------
# Logs — applies to all sub-projects
# ---------------------------------------------------------------------------
[Ll][Oo][Gg][Ss]/
*.[Ll][Oo][Gg]
*.[Ll][Oo][Gg].*

# Test output artifacts — all generated files must go into test-results/ (see Testing artefacts below).
# Convention: scripts MUST write output to test-results/, never to directory root.
# Any stray root-level output files use prefix test-run- and are caught by:
test_output.txt
TestOutput.txt
TestOutput.md
test_run_err.log
test-run-*.txt
*_dump.txt

# Phase run temp files (created by root orchestrator and CI parallel runners)
phase1_*.txt
phase2_*.txt
phase1_*_err.txt
phase2_*_err.txt
p1_*.txt
p1_*_err.txt
p2_*.txt
p2_*_err.txt

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
.env
# .env.example files are committed — they are templates with no real secrets

# ---------------------------------------------------------------------------
# OS artefacts
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
[Dd]esktop.ini
[Tt][Ee][Mm][Pp]/
[Oo][Ll][Dd]/

# ---------------------------------------------------------------------------
# IDEs
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.code-workspace

# ---------------------------------------------------------------------------
# Testing artefacts
# ---------------------------------------------------------------------------
.pytest_cache/
.pytest_basetemp/
**/.pytest_basetemp/
.pytest_basetemp*/
pytest-cache-files-*/
[Tt][Mm][Pp]/
.tmp_tests/
test-results/
playwright-report/
*.[Tt][Mm][Pp]

# Codex session temp manifests (codex_temp_cleanup.py creates these when
# run with --root pointing at this repo; safe to leave gitignored globally)
.codex_tmp/

# ---------------------------------------------------------------------------
# Backup files (auto-created by tools — git history IS the backup)
# Delete .bak* files after every task; never commit them.
# ---------------------------------------------------------------------------
*.[Bb][Aa][Kk]
*.[Bb][Aa][Kk]_*
*.[Xx][Ll][Ss][Mm].[Bb][Aa][Kk]*

# ---------------------------------------------------------------------------
# Coverage
# ---------------------------------------------------------------------------
coverage/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# ---------------------------------------------------------------------------
# Static analysis output files
# ---------------------------------------------------------------------------
# Bandit security scanner output (generated when --output flag is used)
.bandit
bandit_report*.json
bandit_report*.txt
# Pyright output (saved by run_all_tests.py Phase 1 static analysis)
pyright.stderr.txt
pyright.stdout.txt
# pip-audit report output
pip_audit_report*.json
pip_audit_report*.txt
# Script debug / inspection output (never commit intermediate output files)
inspect_output*.txt
*_debug*.txt
*_dump*.txt
# uv lock file (generated by uv package manager — commit for apps, ignore for scripts)
# Scoped: ignore at root; sub-projects commit their own if needed
/uv.lock

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.docker-build-cache/
[Mm][Oo][Cc][Kk][Cc][Aa][Cc][Hh][Ee]/

# ---------------------------------------------------------------------------
# IJT Node Client — project-specific
# (.state/ scoped here — defensive guard; Node Client run_all_tests.py does
#  not currently create .state/ but the entry prevents accidental future commits.)
# ---------------------------------------------------------------------------
OPC_UA_Clients/Release1/IJT_Node_Client/.state/
OPC_UA_Clients/Release1/IJT_Node_Client/tmp/

# ---------------------------------------------------------------------------
# IJT C# Client — project-specific
# ---------------------------------------------------------------------------
OPC_UA_Clients/Release2/IJT_CSharp_Client/.state/
OPC_UA_Clients/Release2/IJT_CSharp_Client/tmp/

# ---------------------------------------------------------------------------
# IJT Web Client — project-specific
# (.state/ scoped here — used by setup_project.py for install timestamp / lock / runtime state)
# ---------------------------------------------------------------------------
OPC_UA_Clients/Release2/IJT_Web_Client/.state/
OPC_UA_Clients/Release2/IJT_Web_Client/tmp/
# Test-fixture temp directories and any pytest basetemp directories
**/tests/fixtures/tmp*/
.pytest_tmp*/
OPC_UA_Clients/Release2/IJT_Web_Client/regression_report.json
OPC_UA_Clients/Release2/IJT_Web_Client/cross_client_regression_report.json

# ---------------------------------------------------------------------------
# IJT Console Client — project-specific
# (.state/ scoped here — used by setup_client.py for tmp working directory)
# ---------------------------------------------------------------------------
OPC_UA_Clients/Release2/IJT_Console_Client/.state/
OPC_UA_Clients/Release2/IJT_Console_Client/tmp/

# ---------------------------------------------------------------------------
# IJT Test Client — project-specific
# (.state/ scoped here — local pytest temp roots and transient test artifacts)
# ---------------------------------------------------------------------------
OPC_UA_Clients/Release2/IJT_Test_Client/.state/
OPC_UA_Clients/Release2/IJT_Test_Client/tmp/

# ---------------------------------------------------------------------------
# OPC UA Servers — project-specific
# ---------------------------------------------------------------------------
OPC_UA_Servers/Release2/OPC_UA_IJT_Server_Simulator/
OPC_UA_Servers/Release2/OPC_UA_IJT_Server_Simulator_Linux/
OPC_UA_Servers/Release1/IJT_OPC_UA_Server_Simulator/Opc.Ua.Di.NodeSet2.xml
OPC_UA_Servers/Release1/IJT_OPC_UA_Server_Simulator/Opc.Ua.Ijt.Tightening.NodeSet2.xml
OPC_UA_Servers/Release1/IJT_OPC_UA_Server_Simulator/Opc.Ua.Machinery.NodeSet2.xml
OPC_UA_Servers/Release1/IJT_OPC_UA_Server_Simulator/Opc.Ua.NodeSet2_1_04.xml
OPC_UA_Servers/Release1/IJT_OPC_UA_Server_Simulator/tighteningapplication.xml
OPC_UA_Servers/Release1/IJT_OPC_UA_Server_Simulator/Usage_IJT_OPC_UA_Server_Simulator.pdf

# ---------------------------------------------------------------------------
# .NET / C# — applies to all C# projects in the repo
# (IJT_CSharp_Client, Types/ sub-libraries, any future C# work)
# ---------------------------------------------------------------------------

# .NET SDK local telemetry/sentinel cache (created on first dotnet run per machine)
.dotnet/
# .NET CLI home directory when DOTNET_CLI_HOME is redirected (e.g., Docker CI)
.dotnet-home/

# Build output directories
[Bb]in/
[Oo]bj/

# Visual Studio solution user options & caches
*.suo
*.user
*.userosscache
*.sln.docstates
.vs/

# NuGet artefacts
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
[Aa][Rr][Tt][Ii][Ff][Aa][Cc][Tt][Ss]/
# NuGet restore lock files (packages.lock.json) are versioned for deterministic restore.

# Publish output
**/publish/
**/PublishOutput/

# Test results
[Tt][Ee][Ss][Tt][Rr][Ee][Ss][Uu][Ll][Tt][Ss]/
*.trx
*.coverage
*.coveragexml

# MSBuild crash logs
MSBuild_*.failure.txt

# ---------------------------------------------------------------------------
# OPC UA PKI / certificates — auto-generated on first run, never commit
# ---------------------------------------------------------------------------
# The OPC Foundation SDK creates these under bin/ on first connection.
# Covered by [Bb]in/ above, but listed explicitly for clarity.
**/PKI/
**/pki/
*.pfx
*.p12

# ---------------------------------------------------------------------------
# actionlint binary — vendored docs and man pages bundled with the binary.
# These are upstream actionlint files, not project documentation.
# The binary itself is caught by the global gitignore (*.exe).
# ---------------------------------------------------------------------------
man/
LICENSE.txt
docs/README.md
docs/checks.md
docs/api.md
docs/usage.md
docs/config.md
docs/install.md
docs/reference.md

# ---------------------------------------------------------------------------
# Session / handoff artefacts
# ---------------------------------------------------------------------------
# AI agent local session state (personal, never commit)
.copilot/
# Local pre-commit cache if PRE_COMMIT_HOME was pointed at repo root
.pre-commit-cache-local/
# Local-only colleague working directory — exists on some machines, never push
# Both cases listed: Windows/macOS are case-insensitive but Linux is not
# Anchored with '/' so only the repo-root Envelope/ dir is ignored, not
# source directories like src/javascripts/views/envelope/ inside the project.
/Envelope/
/envelope/
# Envelope experimental library in IJT web client should remain local-only.
/OPC_UA_Clients/Release2/IJT_Web_Client/src/javascripts/views/envelope/
# Repo-root .state/ guard — created if any tool is accidentally run from repo root
/.state/
# Setup timestamp files — written by setup_client.py / setup_project.py in any Python client
**/.setup_timestamp
