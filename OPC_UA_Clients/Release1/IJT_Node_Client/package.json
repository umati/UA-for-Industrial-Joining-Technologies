{
  "name": "opc-ua-nodejs-client",
  "version": "1.0.0",
  "description": "NodeJS IJT client",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "lint:js": "eslint index.js javascripts/ijt-support/client/node-opcua-interface.mjs scripts/*.mjs",
    "lint:css": "node ./scripts/check-css.mjs",
    "lint": "npm run lint:js && npm run lint:css",
    "regression:connection-established": "node ./scripts/regression-connection-established.mjs",
    "regression:connection-no": "node ./scripts/regression-connection-no.mjs",
    "smoke": "node ./scripts/smoke-test.mjs",
    "test:unit:js": "vitest run",
    "test:unit:js:watch": "vitest",
    "test:unit:js:coverage": "vitest run --coverage",
    "test:e2e": "playwright test tests/e2e/",
    "test": "npm run lint && npm run test:unit:js"
  },
  "author": "Joakim Gustafsson <joakim.gustafsson@atlascopco.com>",
  "license": "ISC",
  "dependencies": {
    "async": "^3.2.6",
    "chart.js": "^4.5.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "node-opcua": "^2.165.0",
    "socket.io": "^4.8.3"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "brace-expansion": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.0.3",
    "eslint-plugin-n": "^17.24.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.54.2",
    "vitest": "^4.1.1"
  }
}
