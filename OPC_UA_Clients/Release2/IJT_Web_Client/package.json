{
  "name": "opc-ua-ijt-client",
  "version": "1.0.0",
  "description": "IJT OPC UA Web Client — Industrial Joining Technologies reference implementation",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "npx serve --listen tcp://127.0.0.1:3000 --no-clipboard .",
    "test": "npm run test:unit:js",
    "test:unit:python": "python run_all_tests.py",
    "test:integration:python": "python run_all_tests.py --integration",
    "test:live:python": "python -m pytest tests/test_opcua_live.py -v",
    "test:unit:js": "vitest run",
    "test:unit:js:coverage": "vitest run --coverage --exclude src/javascripts/views/envelope/tests/unit/automatic-stepwise-performance.test.mjs",
    "test:unit:js:performance": "vitest run src/javascripts/views/envelope/tests/unit/automatic-stepwise-performance.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=smoke --reporter=line",
    "test:e2e:regression": "playwright test --project=regression --reporter=line",
    "test:e2e:features": "playwright test --project=features --reporter=line",
    "test:e2e:report": "playwright show-report test-results/html",
    "test:all": "python run_all_tests.py --all",
    "lint": "eslint src/javascripts config.js --config eslint.config.mjs",
    "lint:fix": "eslint src/javascripts config.js --fix --config eslint.config.mjs",
    "lint:css": "stylelint src/resources/css/*.css",
    "lint:css:fix": "stylelint src/resources/css/*.css --fix",
    "lint:all": "npm run lint && npm run lint:css",
    "lint:precommit": "node ./scripts/precommit-fix-uncommitted.mjs",
    "lint:test:prepush": "npm run lint:all",
    "prepare": "cd ../../.. && husky OPC_UA_Clients/Release2/IJT_Web_Client/.husky",
    "clean": "node -e \"require('fs').rmSync('test-results', {recursive: true, force: true})\""
  },
  "author": "Joakim Gustafsson <joakim.gustafsson@atlascopco.com>",
  "license": "ISC",
  "dependencies": {
    "chart.js": "^4.5.1",
    "mathjs": "^15.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-n": "^18.0.0",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "neostandard": "^0.13.0",
    "serve": "^14.2.6",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "tesseract.js": "^7.0.0",
    "tesseract.js-core": "^7.0.0",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "browserslist": [
    "Chrome >= 120",
    "Edge >= 120",
    "Firefox >= 120",
    "Safari >= 17"
  ],
  "overrides": {
    "compression": "1.8.1",
    "brace-expansion@^1.1.7": "1.1.16",
    "brace-expansion@^5.0.2": "5.0.7",
    "fast-uri@^3.0.1": "^3.1.4"
  }
}
