{
  "name": "opc-ua-ijt-client",
  "version": "1.0.0",
  "description": "IJT client",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "npx serve",
    "test": "npm run test:unit:js",
    "test:unit:python": "python -m pytest tests/python/unit -q",
    "test:integration:python": "python -m pytest tests/python/integration -q -m integration",
    "test:unit:js": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:regression": "playwright test tests/e2e/regression-ui.spec.mjs",
    "test:all": "npm run test:unit:python && npm run test:integration:python && npm run test:unit:js",
    "lint": "eslint Javascripts config.js --config eslint.config.mjs",
    "lint:fix": "eslint Javascripts config.js --fix --config eslint.config.mjs"
  },
  "author": "Joakim Gustafsson <joakim.gustafsson@atlascopco.com>",
  "license": "ISC",
  "dependencies": {
    "chart.js": "^4.5.1",
    "mathjs": "^15.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.54.2",
    "eslint": "^9.39.4",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^17.4.0",
    "neostandard": "^0.13.0",
    "serve": "^14.2.6",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "overrides": {
    "compression": "1.8.1"
  }
}
