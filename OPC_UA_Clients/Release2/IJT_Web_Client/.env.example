# Environment Configuration Example
# Suppress Python bytecode files (__pycache__ / .pyc) — matches Docker behavior
PYTHONDONTWRITEBYTECODE=1
ENV_MAX_AGE_DAYS=14
WS_PORT=8001
NODE_VERSION=24.0.0
# Warn (do not fail) when newer major/minor than this tested baseline is detected.
NODE_TESTED_MAX_MAJOR=24
PYTHON_TESTED_MAX_MINOR=14
# Dependency policy: asyncua is pinned in repo-root constraints.txt to upstream
# SHA 35a77c6b (post-1.2b2; 2026-05-11). Uncomment only to deliberately test a
# verified replacement; setup_project.py will let this override bypass the pin.
# ASYNCUA_VERSION_SPEC=asyncua>=1.2.0
HTTP_PORT=3000
WS_HOST=127.0.0.1
OPCUA_STARTUP_TIMEOUT_SEC=45
OPCUA_STARTUP_POLL_SEC=0.5
OPCUA_CONNECT_RETRIES=8
OPCUA_CONNECT_DELAY_SEC=1.0
OPCUA_CONNECT_MAX_DELAY_SEC=4.0
