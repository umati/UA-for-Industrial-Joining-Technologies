# Environment Configuration Example
ENV_MAX_AGE_DAYS=14
WS_PORT=8001
NODE_VERSION=24.0.0
# Warn (do not fail) when newer major/minor than this tested baseline is detected.
NODE_TESTED_MAX_MAJOR=24
PYTHON_TESTED_MAX_MINOR=14
# Dependency policy: allow future stable asyncua by default. Keep --pre fallback enabled.
ASYNCUA_VERSION_SPEC=asyncua>=1.2b1
ASYNCUA_ALLOW_PRE=1
HTTP_PORT=3000
WS_HOST=127.0.0.1
OPCUA_STARTUP_TIMEOUT_SEC=45
OPCUA_STARTUP_POLL_SEC=0.5
OPCUA_CONNECT_RETRIES=8
OPCUA_CONNECT_DELAY_SEC=1.0
OPCUA_CONNECT_MAX_DELAY_SEC=4.0
