#!/usr/bin/env sh
set -eu

REPO_ROOT="$(git rev-parse --show-toplevel)"
PROJECT_DIR="$REPO_ROOT/OPC_UA_Clients/Release2/IJT_Web_Client"

if [ ! -d "$PROJECT_DIR" ]; then
  echo "[pre-push] Project directory not found: $PROJECT_DIR"
  exit 1
fi

cd "$PROJECT_DIR"

run_and_check() {
  label="$1"
  shift

  echo "[pre-push] Running: $label"
  output="$($@ 2>&1)" || {
    echo "$output"
    echo "[pre-push] Blocked: $label failed."
    exit 1
  }
  echo "$output"

  if echo "$output" | grep -E "[0-9]+ skipped" >/dev/null 2>&1; then
    if [ "${STRICT_TESTS:-0}" = "1" ]; then
      echo "[pre-push] Blocked: $label had skipped tests and STRICT_TESTS=1."
      exit 1
    fi
    echo "[pre-push] Warning: $label had skipped tests."
  fi
}

run_and_check "non-integration tests" python run_tests.py
run_and_check "integration tests" python run_tests.py --integration

echo "[pre-push] All required tests passed. Push allowed."
