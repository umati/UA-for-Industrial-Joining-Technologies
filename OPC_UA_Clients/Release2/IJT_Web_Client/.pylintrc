[MAIN]
# Run pylint from the IJT_Web_Client directory so imports resolve correctly.
# The Python package root is src/ (added to sys.path via conftest.py).
# pylint cannot replicate the runtime sys.path, so import-error and
# no-member for asyncua (whose members are generated from OPC UA XML at
# runtime) are suppressed globally.

[MESSAGES CONTROL]
disable =
    # E0401: import-error
    #   False positive: python.xxx imports resolve at runtime via sys.path
    #   manipulation in conftest.py / pytest.ini.  pylint is run from
    #   IJT_Web_Client/ where "Python" is not a top-level package.
    import-error,

    # E1101: no-member
    #   asyncua dynamically generates ua.JoiningProcessIdentificationDataType,
    #   ua.EntityDataType and other companion-spec types at startup by parsing
    #   OPC UA NodeSet XML files.  pylint cannot see these at static-analysis
    #   time, so all no-member hits on asyncua.ua.* are false positives.
    no-member,

    # W0718: broad-exception-caught
    #   OPC UA code must handle broad exceptions because asyncua can raise
    #   many different exception types depending on server state, network
    #   conditions, and protocol version.  Narrowing every catch would make
    #   the error-handling incomplete and fragile.
    broad-exception-caught,

    # W1203 / W1201: logging-fstring-interpolation / logging-not-lazy
    #   The codebase deliberately uses f-strings in log calls for
    #   readability and consistency.  The lazy-% pattern offers a minor
    #   performance benefit only when the log level is disabled, which is
    #   not the primary concern here.
    logging-fstring-interpolation,
    logging-not-lazy,

    # C0103: invalid-name
    #   OPC UA companion spec and asyncua use PascalCase for event fields
    #   (EventType, Result, Message, etc.) and the codebase mirrors that.
    #   Legacy camelCase variables (nodeId, methodNode, etc.) are kept for
    #   consistency with the existing API surface.
    invalid-name,

    # C0411: wrong-import-order
    #   Minor style difference — not a correctness issue.
    wrong-import-order,

    # C0415: import-outside-toplevel
    #   serialize_data.py imports ijt_logger inside functions to avoid
    #   circular imports.  This is intentional.
    import-outside-toplevel,

    # R0801: duplicate-code
    #   EventHandler and ResultEventHandler share queue-worker logic.
    #   The duplication is tracked and will be resolved in the
    #   JointManager/EntityManager dedup refactor (L8).
    duplicate-code,

    # R0902: too-many-instance-attributes
    #   Connection and EventHandler manage multiple OPC UA state fields
    #   (subscriptions, handlers, client, root, etc.) by necessity.
    too-many-instance-attributes,

    # R0903: too-few-public-methods
    #   Short dataclasses and single-responsibility handler classes.
    too-few-public-methods,

    # R0911, R0912, R0914, R0915: too-many-{return-statements,branches,locals,statements}
    #   methodcall() and utils logging functions are complex by protocol
    #   necessity — splitting them would harm readability without benefit.
    too-many-return-statements,
    too-many-branches,
    too-many-locals,
    too-many-statements,

[FORMAT]
max-line-length = 120

[DESIGN]
max-args = 10
