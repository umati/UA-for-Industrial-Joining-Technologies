    "BaseResultTransferOptionsDataType": {
      "type": "object",
      "properties": {
        "ResultId": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ProcessingTimesDataType": {
      "type": "object",
      "properties": {
        "StartTime": {
          "type": "string",
          "format": "date-time"
        },
        "EndTime": {
          "type": "string",
          "format": "date-time"
        },
        "AcquisitionDuration": {
