        "ExternalRecipeId": {
          "type": [
            "string",
            "null"
          ]
        },
        "InternalRecipeId": {
          "type": [
            "string",
            "null"
          ]
        },
        "ProductId": {
          "type": [
            "string",
            "null"
          ]
        },
        "ExternalConfigurationId": {
          "type": [
            "string",
            "null"
          ]
        },
        "InternalConfigurationId": {
          "type": [
            "string",
            "null"
          ]
        },
        "JobId": {
          "type": [
            "string",
            "null"
          ]
