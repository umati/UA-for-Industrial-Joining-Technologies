{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "ResultEvaluationEnum": {
      "anyOf": [
        {
          "const": "Undefined_0",
          "title": "Undefined"
        },
        {
          "const": "OK_1",
          "title": "OK"
        },
        {
          "const": "NotOK_2",
          "title": "NotOK"
        },
        {
          "const": "NotDecidable_3",
          "title": "NotDecidable"
        }
      ]
    },
    "ResultTransferOptionsDataType": {
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/BaseResultTransferOptionsDataType"
        }
      ],
      "properties": {}
