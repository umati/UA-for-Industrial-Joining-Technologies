<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--
      <clear /> removes all sources inherited from parent/global NuGet.Config files.
      The packageSourceMapping clear below does the same for inherited source mappings.
      This ensures the client-compat build (OpcUaClientOnly=true) uses only nuget.org,
      bypassing global PackageSourceMapping that would block OPCFoundation.* and
      force System.Threading.Tasks.Extensions to the VS Offline Packages (only has 4.0.0).
      For standard builds this nuget.config is still active but harmless — all packages
      are available on nuget.org. Add private mirrors/proxies explicitly after the
      clear entries if restore ever needs them.
    -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <clear />
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
