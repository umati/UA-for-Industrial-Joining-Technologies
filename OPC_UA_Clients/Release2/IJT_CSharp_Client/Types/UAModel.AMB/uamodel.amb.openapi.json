          },
          "NodeId": {
            "type": "string",
            "format": "UaNodeId"
          }
        },
        "description": "A human-readable name of something plus optionally the NodeId in case the something is represented in the AddressSpace"
      },
      "MaintenanceMethodEnum": {
        "enum": [
          0,
          1
        ],
        "type": "integer",
        "description": "[Link to specification]().",
        "format": "int32",
        "x-enum-varnames": [
          "Local",
          "Remote"
        ]
      }
    }
  }
}