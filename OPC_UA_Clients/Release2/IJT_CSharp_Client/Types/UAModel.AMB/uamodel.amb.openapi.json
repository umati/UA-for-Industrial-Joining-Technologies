{
  "openapi": "3.0.4",
  "info": {
    "title": "AMB",
    "description": "A placeholder API that allows OpenAPI tools to be used to generate code for a companion specification.",
    "version": "1.01.1"
  },
  "servers": [
    {
      "url": "http://localhost:4840"
    }
  ],
  "paths": {
