      "get": {
        "operationId": "Get",
        "responses": {
          "200": {
            "description": "ModelDataTypes",
            "content": {
              "application/json": {
                "schema": {
                  "title": "Response",
                  "properties": {
                    "RootCauseDataType": {
                      "$ref": "#/components/schemas/RootCauseDataType"
                    },
                    "NameNodeIdDataType": {
                      "$ref": "#/components/schemas/NameNodeIdDataType"
                    },
                    "MaintenanceMethodEnum": {
                      "$ref": "#/components/schemas/MaintenanceMethodEnum"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LocalizedText": {
        "type": "object",
        "properties": {
          "Locale": {
            "type": "string",
            "format": "rfc3066"
          },
          "Text": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "description": "[Link to specification](https://reference.opcfoundation.org/Core/Part3/v105/docs/8.5)."
      },
      "RootCauseDataType": {
        "type": "object",
        "properties": {
          "RootCauseId": {
            "type": "string",
            "format": "UaNodeId"
          },
