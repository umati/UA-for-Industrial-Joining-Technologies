{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "RootCauseDataType": {
      "type": "object",
      "properties": {
        "RootCauseId": {
          "type": "string",
          "format": "UaNodeId"
        },
        "RootCause": {
          "$ref": "https://opcfoundation.org/schemas/OpenApi/opc.ua.services.jsonschema.json#/$defs/LocalizedText"
        }
      }
    },
    "NameNodeIdDataType": {
      "type": "object",
      "properties": {
